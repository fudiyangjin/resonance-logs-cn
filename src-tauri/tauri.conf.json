{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Resonance Logs - Global",
  "version": "1.0.7",
  "identifier": "com.resonance-logs-global",
  "build": {
    "beforeDevCommand": "npm run dev:tauri-static",
    "beforeBuildCommand": "npm run build:stop-windivert",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Resonance Logs - Global v1.0.7 - Live",
        "label": "live",
        "url": "/live/dps",
        "shadow": false,
        "decorations": false,
        "transparent": true,
        "minWidth": 410,
        "minHeight": 120,
        "alwaysOnTop": true,
        "skipTaskbar": true
      },
      {
        "title": "Resonance Logs - Global v1.0.7 - Main",
        "label": "main",
        "url": "/main/dps",
        "width": 1200,
        "height": 800,
        "minWidth": 855,
        "minHeight": 300,
        "visible": false,
        "transparent": false
      },
      {
        "title": "Game Overlay",
        "label": "game-overlay",
        "url": "/game-overlay",
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "width": 1280,
        "height": 960,
        "visible": false,
        "resizable": true,
        "shadow": false,
        "maximizable": false
      },
      {
        "title": "Monster Overlay",
        "label": "monster-overlay",
        "url": "/monster-overlay",
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "width": 1280,
        "height": 960,
        "visible": false,
        "resizable": true,
        "shadow": false,
        "maximizable": false
      },
      {
        "title": "Resonance Logs - Global v1.0.7 - Event Logger",
        "label": "event-logger",
        "url": "/event-logger",
        "width": 1200,
        "height": 760,
        "minWidth": 900,
        "minHeight": 520,
        "visible": false,
        "transparent": false,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "copyright": "GNU Affero General Public License v3.0",
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "./WinDivert.dll",
      "./WinDivert64.sys",
      "../parser-data/",
      "../src/lib/locales/"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ5RTQ4NzgzQTlFM0Q0QzQKUldURTFPT3BnNGZrU1dJY01aaGNwelZxc3U0UGpGTVJaQ2FpcVdQd1FsTVVXSDRBakFxbkVSNjkK",
      "endpoints": [
        "https://github.com/donneeee/resonance-logs-global/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "windows": {
        "installMode": "basicUi"
      }
    }
  }
}
